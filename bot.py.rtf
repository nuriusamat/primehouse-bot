async def get_add_conditions(update: Update, context: ContextTypes.DEFAULT_TYPE):\
    query = update.callback_query\
    await query.answer()\
\
    if query.data == "ac_done":\
        return await calculate_result(query, context)\
\
    key = query.data.replace("ac_", "")\
    selected = context.user_data.get("add_conditions", [])\
\
    if key in selected:\
        selected.remove(key)\
    else:\
        selected.append(key)\
    context.user_data["add_conditions"] = selected\
\
    # \uc0\u1055 \u1077 \u1088 \u1077 \u1088 \u1080 \u1089 \u1086 \u1074 \u1099 \u1074 \u1072 \u1077 \u1084  \u1082 \u1085 \u1086 \u1087 \u1082 \u1080  \u1089  \u1086 \u1090 \u1084 \u1077 \u1090 \u1082 \u1072 \u1084 \u1080 \
    keyboard = []\
    for k, (name, desc, pct) in ADD_CONDITIONS_LIST.items():\
        mark = "\uc0\u9989 " if k in selected else "\u9744 "\
        keyboard.append([InlineKeyboardButton(\
            f"\{mark\} \{name\} (+\{int(pct*100)\}%)", callback_data=f"ac_\{k\}"\
        )])\
    keyboard.append([InlineKeyboardButton("\uc0\u10145 \u65039  \u1056 \u1072 \u1089 \u1089 \u1095 \u1080 \u1090 \u1072 \u1090 \u1100  \u1089 \u1090 \u1086 \u1080 \u1084 \u1086 \u1089 \u1090 \u1100 ", callback_data="ac_done")])\
\
    await query.edit_message_text(\
        "\uc0\u10133  *\u1044 \u1086 \u1087 \u1086 \u1083 \u1085 \u1080 \u1090 \u1077 \u1083 \u1100 \u1085 \u1099 \u1077  \u1091 \u1089 \u1083 \u1086 \u1074 \u1080 \u1103 * (\u1090 \u1072 \u1073 \u1083 . 10 \u1057 \u1041 \u1062 \u1055 ):\\n"\
        f"_\uc0\u1042 \u1099 \u1073 \u1088 \u1072 \u1085 \u1086 : \{len(selected)\} \u1087 \u1091 \u1085 \u1082 \u1090 \u1086 \u1074 _\\n\\n"\
        "\uc0\u1053 \u1072 \u1078 \u1084 \u1080 \u1090 \u1077  \u1085 \u1072  \u1087 \u1091 \u1085 \u1082 \u1090  \u1076 \u1083 \u1103  \u1074 \u1099 \u1073 \u1086 \u1088 \u1072 /\u1089 \u1085 \u1103 \u1090 \u1080 \u1103  \u1086 \u1090 \u1084 \u1077 \u1090 \u1082 \u1080 :",\
        reply_markup=InlineKeyboardMarkup(keyboard),\
        parse_mode="Markdown"\
    )\
    return ADD_CONDITIONS\
